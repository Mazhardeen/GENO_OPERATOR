import os,json,subprocess,shutil,sys

BASE=os.path.expanduser("~/GENO_OPERATOR")
REG=os.path.join(BASE,"geno_engine_registry.json")

def load_registry():
    if not os.path.exists(REG):
        print("Registry missing")
        return {}
    with open(REG) as f:
        return json.load(f)

def check_engine(name,path):

    # self engine special handling
    if "geno_super_self_repair_engine" in name:
        return "SELF-CHECK"

    if not os.path.exists(path):
        return "MISSING"

    try:
        subprocess.run(["python3",path],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        timeout=5)
        return "OK"
    except:
        return "ERROR"

def backup_engine(name,path):
    try:
        shutil.copy(path,path+".bak")
        print("Backup created:",name)
    except:
        pass

def run():

    engines=load_registry()

    if not engines:
        print("No engines registered")
        return

    print("\n=== GENO SUPER SELF REPAIR ENGINE ===\n")

    ok=0

    for name,path in engines.items():

        status=check_engine(name,path)

        print(f"{name:<35} {status}")

        if status=="OK" or status=="SELF-CHECK":
            ok+=1
        else:
            backup_engine(name,path)

    print("\nTOTAL:",len(engines))
    print("WORKING:",ok)

    if ok==len(engines):
        print("SYSTEM STATUS: PERFECT")
    else:
        print("SYSTEM STATUS: REPAIR REQUIRED")

if __name__=="__main__":
    run()
